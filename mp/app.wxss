/* 全局样式：中性灰白主题 */
page {
  --bg: #f5f5f5;
  --card: #ffffff;
  --text: #333333;
  --text-weak: #999999;
  --line: #eeeeee;
  --primary: #4a4a4a;
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", Helvetica, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx;
}

.card {
  background: var(--card);
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.btn {
  border-radius: 999rpx;
  font-size: 30rpx;
  padding: 20rpx 0;
  text-align: center;
  border: none;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
}

.btn-ghost {
  background: #fff;
  color: var(--text);
  border: 1rpx solid var(--line);
}

.muted {
  color: var(--text-weak);
  font-size: 24rpx;
}
