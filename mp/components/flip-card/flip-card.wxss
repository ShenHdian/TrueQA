.flip {
  width: 100%;
  height: 100%;
  perspective: 1200rpx;
}
.flip-inner {
  position: relative;
  width: 100%;
  height: 100%;
  transition: transform 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  transform-style: preserve-3d;
}
.flip.flipped .flip-inner {
  transform: rotateY(180deg);
}
.face {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  box-sizing: border-box;
}
.front {
  background: linear-gradient(135deg, #e9e9e9, #cfcfcf);
  color: #8a8a8a;
  font-size: 120rpx;
  font-weight: 700;
}
.back {
  background: #ffffff;
  transform: rotateY(180deg);
  padding: 36rpx;
  text-align: center;
}
