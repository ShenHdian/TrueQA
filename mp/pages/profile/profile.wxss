.profile .user {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  line-height: normal;
  border: none;
}
.avatar-btn::after {
  border: none;
}
.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-empty {
  color: #999;
  font-size: 48rpx;
}
.avatar-img {
  width: 140rpx;
  height: 140rpx;
}
.nick {
  margin-top: 20rpx;
  font-size: 34rpx;
  text-align: center;
  min-width: 240rpx;
}
.meta {
  display: flex;
  gap: 40rpx;
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #555;
}
.expbar {
  width: 100%;
  height: 14rpx;
  background: #eee;
  border-radius: 999rpx;
  margin-top: 24rpx;
  overflow: hidden;
}
.expfill {
  height: 100%;
  background: #4a4a4a;
  transition: width 0.4s ease;
}
.tip {
  text-align: center;
  margin-top: 40rpx;
  padding: 0 40rpx;
}
