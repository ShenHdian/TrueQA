.index .head {
  text-align: center;
  margin-bottom: 16rpx;
}
.index .title {
  font-size: 44rpx;
  font-weight: 700;
}
.index .sub {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}
.stage {
  position: relative;
  height: 440rpx;
  margin: 32rpx 0;
}
.slot-wrap,
.card-wrap {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 440rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.flip-card-el {
  width: 86%;
  height: 380rpx;
}
.q-front {
  font-size: 140rpx;
  color: #aaa;
  font-weight: 700;
}
.q-back {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}
.q-tag {
  font-size: 22rpx;
  color: #999;
  background: #f2f2f2;
  padding: 4rpx 18rpx;
  border-radius: 999rpx;
  margin-bottom: 24rpx;
}
.q-text {
  font-size: 36rpx;
  line-height: 1.5;
  color: #222;
  padding: 0 12rpx;
}
.q-anger {
  margin-top: 28rpx;
  font-size: 24rpx;
  color: #c0392b;
}
.draw-btn {
  margin-top: 8rpx;
}
.battle-entry {
  margin-top: 24rpx;
}
.tip {
  text-align: center;
  margin-top: 28rpx;
}
